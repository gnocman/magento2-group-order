<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="SmartOSC\GroupOrder\Block\QuoteUrl" name="product_list_toolbar" cacheable="false" template="SmartOSC_GroupOrder::toolbar/toolbar.phtml">
                <arguments>
                    <argument name="cart_item_customer_view_model" xsi:type="object">SmartOSC\GroupOrder\ViewModel\CartItemCustomer</argument>
                </arguments>
                <block class="Magento\Theme\Block\Html\Pager" name="product_list_toolbar_pager"/>
            </block>
        </referenceContainer>
    </body>
</page>
