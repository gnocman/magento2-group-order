<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="product_list_toolbar" template="SmartOSC_GroupOrder::toolbar/toolbar.phtml">
            <block class="SmartOSC\GroupOrder\Block\QuoteUrl"
                   name="grouporder.toolbar.button"
                   as="grouporder_button"
                   cacheable="false"
                   template="SmartOSC_GroupOrder::toolbar/button.phtml">
                <arguments>
                    <argument name="cart_item_customer_view_model" xsi:type="object">SmartOSC\GroupOrder\ViewModel\CartItemCustomer</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
