<?php
/**
 * @var \SmartOSC\GroupOrder\Block\QuoteUrl $block
 */
$quoteUrl = $block->getQuoteUrl();
$groupOrderToken = $this->getRequest()->getParam('key');
$isEnabled = $this->helper(\SmartOSC\GroupOrder\Helper\Data::class)->isEnabled();

/** @var \SmartOSC\GroupOrder\ViewModel\CartItemCustomer $viewModel */
$viewModel = $block->getData('cart_item_customer_view_model');
$isCustomerLoggedIn = $viewModel ? $viewModel->isLoggedIn() : false;
?>

<?php if ($isEnabled && $isCustomerLoggedIn && $groupOrderToken === null): ?>
    <button onclick="copyGroupOrderUrl('<?= $block->escapeJs(
        "Let's choose your favorite items on any website together! Just choose the item you like and add it to the group's cart and you're done. Click the link below! " . $quoteUrl
    ) ?>')">
        <?= $block->escapeHtml(__('Initiate A Group Order On This Page.')) ?>
    </button>
<?php endif; ?>

<script>
    function copyGroupOrderUrl(text) {
        if (navigator.clipboard) {
            navigator.clipboard.writeText(text).then(function () {
                alert('<?= $block->escapeJs(__('Group Order URL copied!')) ?>');
            });
        } else {
            var dummy = document.createElement('input');
            document.body.appendChild(dummy);
            dummy.setAttribute('value', text);
            dummy.select();
            document.execCommand('copy');
            document.body.removeChild(dummy);
            alert('<?= $block->escapeJs(__('Group Order URL copied!')) ?>');
        }
    }
</script>
